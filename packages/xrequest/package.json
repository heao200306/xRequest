{
  "name": "xrequest",
  "version": "1.0.0",
  "description": "A lightweight HTTP request library with dual-engine support (XHR & Fetch)",
  "keywords": [
    "xrequest",
    "http",
    "request",
    "ajax",
    "fetch",
    "xhr",
    "axios"
  ],
  "author": {
    "name": "xRequest Team",
    "url": "https://github.com/xrequest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xrequest/xrequest.git"
  },
  "homepage": "https://github.com/xrequest/xrequest#readme",
  "bugs": {
    "url": "https://github.com/xrequest/xrequest/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}